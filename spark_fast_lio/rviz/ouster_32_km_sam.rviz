    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /keypoints1/Status1
        - /KM-SAM curr scan1/Topic1
        - /KM-SAM corr1/Topic1
        - /TF1/Tree1
      Splitter Ratio: 0.6009975075721741
    Tree Height: 895
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded:
      - /2D Goal Pose1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz_common/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: curr scan
